from pydantic import BaseModel, Field
from typing import Optional


class TodoBase(BaseModel):
    """Base model for a Todo item, containing common fields."""
    title: str = Field(..., min_length=1, max_length=100, example="Learn FastAPI")
    description: Optional[str] = Field(None, max_length=300, example="Read the official documentation and build a small app.")
    completed: bool = Field(False, example=False)


class TodoCreate(TodoBase):
    """Model for creating a new Todo item. Inherits from TodoBase.
    ID is not included here as it's typically generated by the server.
    """
    pass


class TodoUpdate(BaseModel):
    """Model for updating an existing Todo item. All fields are optional for partial updates."""
    title: Optional[str] = Field(None, min_length=1, max_length=100, example="Master FastAPI")
    description: Optional[str] = Field(None, max_length=300, example="Build a more complex application with authentication.")
    completed: Optional[bool] = Field(None, example=True)


class Todo(TodoBase):
    """Full Todo model, including the ID. Used for responses."""
    id: int = Field(..., gt=0, example=1)  # ID should be a positive integer

    class Config:
        from_attributes = True  # Enables Pydantic to work with ORM models or arbitrary class instances
        json_schema_extra = {
            "example": {
                "id": 1,
                "title": "Buy groceries",
                "description": "Milk, eggs, bread, and fruits",
                "completed": False
            }
        }
