from fastapi import APIRouter, HTTPException, status
from typing import List
from app.models import Todo, TodoCreate, TodoUpdate

# Create an APIRouter instance for organizing routes
router = APIRouter()

# In-memory database for demonstration purposes
# In a real application, this would be replaced with a database (e.g., PostgreSQL, MongoDB)
todos_db: List[Todo] = []
next_todo_id = 1


@router.get("/health", status_code=status.HTTP_200_OK, tags=["Health"])
async def health_check():
    """
    Checks the health of the API.

    Returns:
        dict: A dictionary with a status message.
    """
    return {"status": "healthy", "message": "Todo API is running"}


@router.post("/todos/", response_model=Todo, status_code=status.HTTP_201_CREATED, tags=["Todos"])
async def create_todo(todo: TodoCreate):
    """
    Creates a new Todo item.

    Args:
        todo (TodoCreate): The data for the new Todo item.

    Returns:
        Todo: The newly created Todo item with its assigned ID.
    """
    global next_todo_id
    # Create a new Todo instance with an assigned ID and data from TodoCreate
    new_todo = Todo(id=next_todo_id, **todo.model_dump())
    todos_db.append(new_todo)
    next_todo_id += 1
    return new_todo


@router.get("/todos/", response_model=List[Todo], tags=["Todos"])
async def read_todos():
    """
    Retrieves all Todo items.

    Returns:
        List[Todo]: A list of all Todo items.
    """
    return todos_db


@router.get("/todos/{todo_id}", response_model=Todo, tags=["Todos"])
async def read_todo(todo_id: int):
    """
    Retrieves a single Todo item by its ID.

    Args:
        todo_id (int): The ID of the Todo item to retrieve.

    Raises:
        HTTPException: If the Todo item with the given ID is not found.

    Returns:
        Todo: The requested Todo item.
    """
    for todo in todos_db:
        if todo.id == todo_id:
            return todo
    raise HTTPException(
        status_code=status.HTTP_404_NOT_FOUND,
        detail=f"Todo with id {todo_id} not found"
    )


@router.put("/todos/{todo_id}", response_model=Todo, tags=["Todos"])
async def update_todo(todo_id: int, todo_update: TodoUpdate):
    """
    Updates an existing Todo item.

    Args:
        todo_id (int): The ID of the Todo item to update.
        todo_update (TodoUpdate): The updated data for the Todo item.

    Raises:
        HTTPException: If the Todo item with the given ID is not found.

    Returns:
        Todo: The updated Todo item.
    """
    for index, todo in enumerate(todos_db):
        if todo.id == todo_id:
            # Use model_dump(exclude_unset=True) to only update provided fields
            updated_data = todo_update.model_dump(exclude_unset=True)
            for key, value in updated_data.items():
                setattr(todos_db[index], key, value)
            return todos_db[index]
    raise HTTPException(
        status_code=status.HTTP_404_NOT_FOUND,
        detail=f"Todo with id {todo_id} not found"
    )


@router.delete("/todos/{todo_id}", status_code=status.HTTP_204_NO_CONTENT, tags=["Todos"])
async def delete_todo(todo_id: int):
    """
    Deletes a Todo item by its ID.

    Args:
        todo_id (int): The ID of the Todo item to delete.

    Raises:
        HTTPException: If the Todo item with the given ID is not found.

    Returns:
        None: As per HTTP 204 No Content.
    """
    global todos_db
    initial_len = len(todos_db)
    todos_db = [todo for todo in todos_db if todo.id != todo_id]
    if len(todos_db) == initial_len:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Todo with id {todo_id} not found"
        )
    return None # HTTP 204 No Content typically returns no body